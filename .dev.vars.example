# Copy this file to .dev.vars and replace placeholder values before running
# projects that need local secrets.
SESSION_SECRET=change-this-to-a-long-random-secret
# Optional: enable the local-only demo workspace at /demo. Keep this out of
# deployed environments.
# DEMO_MODE=true
# Recommended when storing channel credentials: keep a separate key for
# encrypted adapter credentials instead of reusing SESSION_SECRET.
# APP_ENCRYPTION_SECRET=change-this-to-a-different-long-random-secret
